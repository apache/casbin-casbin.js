{
    "transform": {
        "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "testEnvironment": "./jest.environment.js",
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"],
    "coveragePathIgnorePatterns": [
        "/node_modules/"
      ]
}